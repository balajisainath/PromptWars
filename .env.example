# ============================================================
# AI Travel Planning Engine — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# --- AI ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# --- Firebase ---
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="your_firebase_private_key"
FIREBASE_WEB_API_KEY=your_firebase_web_api_key

# --- Weather ---
OPENWEATHER_API_KEY=your_openweather_api_key_here

# --- Amadeus (sandbox) ---
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret

# --- PostgreSQL ---
POSTGRES_USER=travelai
POSTGRES_PASSWORD=travelai_secret
POSTGRES_DB=travelai
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://travelai:travelai_secret@postgres:5432/travelai

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- Qdrant ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_URL=http://qdrant:6333

# --- Neo4j (Graphiti) ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=graphiti_secret

# --- RabbitMQ ---
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=travelai
RABBITMQ_PASSWORD=rabbitmq_secret
RABBITMQ_URL=amqp://travelai:rabbitmq_secret@rabbitmq:5672/

# --- MinIO ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_secret
MINIO_ENDPOINT=minio:9000

# --- Backend ---
SECRET_KEY=change_this_to_a_random_secret_key_256bits
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Geo Service ---
GEO_SERVICE_URL=http://geo-service:8080

# --- Graphiti Service ---
GRAPHITI_SERVICE_URL=http://graphiti-service:8001

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_web_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
